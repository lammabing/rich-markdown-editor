{
  "name": "rich-markdown-editor",
  "description": "A modern, feature-rich markdown editor with real-time in-place rendering, slash commands, and extensive GFM support.",
  "repository": {
    "type": "git",
    "url": "https://github.com/lammabing/rich-markdown-editor.git"
  },
  "homepage": "https://github.com/lammabing/rich-markdown-editor",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "echo 'NOTE: If the page appears stuck/blank, browser extensions (ad blockers, style changers, dark mode plugins) may interfere. Try Incognito mode.' && node --max-old-space-size=4096 node_modules/.bin/vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@tiptap/core": "^3.20.0",
    "@tiptap/extension-character-count": "^3.20.0",
    "@tiptap/extension-code-block-lowlight": "^3.20.0",
    "@tiptap/extension-color": "^3.20.0",
    "@tiptap/extension-placeholder": "^3.20.0",
    "@tiptap/extension-table": "^3.20.0",
    "@tiptap/extension-table-cell": "^3.20.0",
    "@tiptap/extension-table-header": "^3.20.0",
    "@tiptap/extension-table-row": "^3.20.0",
    "@tiptap/extension-task-item": "^3.20.0",
    "@tiptap/extension-task-list": "^3.20.0",
    "@tiptap/extension-text-style": "^3.20.0",
    "@tiptap/extension-underline": "^3.20.0",
    "@tiptap/pm": "^3.20.0",
    "@tiptap/react": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "@tiptap/suggestion": "^3.20.0",
    "@types/dompurify": "^3.0.5",
    "@types/emoji-mart": "^3.0.14",
    "@types/katex": "^0.16.8",
    "dompurify": "^3.3.1",
    "emoji-mart": "^5.6.0",
    "katex": "^0.16.33",
    "lowlight": "^3.3.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "shiki": "^3.23.0",
    "tippy.js": "^6.3.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.24",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
